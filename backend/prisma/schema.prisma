// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   @default("CASEWORKER")
  cases     Case[]
  assessments RiskAssessment[]
  createdAt DateTime @default(now())
}

model RiskAssessment {
  id              String   @id @default(uuid())
  caseId          String   @unique
  case            Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  riskLevel       String
  score           Float    @default(0)
  factors         String[] @default([])
  recommendations String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Resource {
  id        String   @id @default(uuid())
  name      String
  category  String
  capacity  Int
  available Int      @default(0)
  isActive  Boolean  @default(true)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  cases     Case[]
}

model Case {
  id                String             @id @default(uuid())
  userId            String?
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  title             String
  description       String
  status            String             @default("NEW")
  urgencyScore      Int?
  categoryTag       String?
  riskFactors       String[]           @default([])
  assignedResourceId String?
  assignedResource  Resource?          @relation(fields: [assignedResourceId], references: [id], onDelete: SetNull)
  enrichedAt        DateTime?
  routedAt          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  assessment        RiskAssessment?
}

// ============================================================================
// SENTINEL D - AUTONOMOUS SYSTEM MODELS
// ============================================================================

model CivicResourceSnapshot {
  id              String   @id @default(uuid())
  externalId      String   @unique
  name            String
  resourceType    String   @db.VarChar(50)
  provider        String   @db.VarChar(100)
  address         String
  city            String
  capacity        Int?
  available       Int?
  verified        Boolean  @default(true)
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  
  @@index([resourceType])
  @@index([provider])
  @@index([lastSyncedAt])
}

model SentinelHeartbeat {
  id              String   @id @default(uuid())
  timestamp       DateTime @default(now())
  uptime          Int
  memoryHeapUsed  Int
  memoryHeapTotal Int
  cpuUser         Int
  cpuSystem       Int
  status          String   @db.VarChar(20)
  
  @@index([timestamp])
  @@index([status])
}

model TelemetryEvent {
  id              String   @id @default(uuid())
  traceId         String
  eventType       String   @db.VarChar(100)
  severity        String   @db.VarChar(20)
  payload         String   @db.Text
  source          String   @db.VarChar(50)
  timestamp       DateTime @default(now())
  
  @@index([traceId])
  @@index([eventType])
  @@index([severity])
  @@index([timestamp])
}

model DriftReport {
  id              String   @id @default(uuid())
  hasDrift        Boolean
  issueCount      Int
  details         String   @db.Text
  severity        Int
  timestamp       DateTime @default(now())
  
  @@index([hasDrift])
  @@index([severity])
  @@index([timestamp])
}

// ============================================================================
// SENTINEL ENGINE MODELS
// ============================================================================

model SentinelMetric {
  id              String   @id @default(uuid())
  metricType      String   @db.VarChar(50)
  resourceName    String   @db.VarChar(100)
  value           Float
  unit            String   @db.VarChar(20)
  timestamp       DateTime @default(now())
  
  @@index([resourceName])
  @@index([metricType])
  @@index([timestamp])
}

model SentinelCircuitState {
  id              String   @id @default(uuid())
  resourceName    String   @unique @db.VarChar(100)
  state           String   @db.VarChar(20)
  failureCount    Int      @default(0)
  lastFailureTime DateTime?
  updatedAt       DateTime @updatedAt
  
  @@index([state])
}

model NormalizationLog {
  id              String   @id @default(uuid())
  provider        String   @db.VarChar(100)
  totalRecords    Int
  successCount    Int
  failureCount    Int
  errorDetails    String?  @db.Text
  timestamp       DateTime @default(now())
  
  @@index([provider])
  @@index([timestamp])
}

// ============================================================================
// ENCRYPTION MODELS
// ============================================================================

model EncryptedResource {
  id              String   @id @default(uuid())
  resourceType    String   @db.VarChar(50)
  ciphertext      Bytes
  iv              Bytes
  authTag         Bytes
  encryptedDek    Bytes
  salt            Bytes
  keyVersion      Int      @default(1)
  associatedId    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  
  @@index([resourceType])
  @@index([keyVersion])
  @@index([createdAt])
}

model VaultAuditLog {
  id              String   @id @default(uuid())
  eventType       String   @db.VarChar(100)
  component       String   @db.VarChar(50) @default("SentinelEngine")
  resourceId      String?
  eventData       String?  @db.Text
  result          String   @db.VarChar(20)
  errorCode       String?  @db.VarChar(50)
  timestamp       DateTime @default(now())
  
  @@index([eventType])
  @@index([timestamp])
  @@index([result])
}

// ============================================================================
// LOAD MONITORING & AUTO-SCALING MODELS
// ============================================================================

model PlatformMetric {
  id              String   @id @default(uuid())
  totalRequests   Int
  totalCapacity   Int
  cpuUsage        Float
  memoryUsage     Float
  errorRate       Float
  avgResponseTime Float
  healthStatus    String   @db.VarChar(20)
  timestamp       DateTime @default(now())
  
  @@index([healthStatus])
  @@index([timestamp])
}

model EngineClone {
  id              String   @id @default(uuid())
  engineType      String   @db.VarChar(50)
  parentInstanceId String  @db.VarChar(100)
  status          String   @db.VarChar(20)
  maxCapacity     Int
  activeRequests  Int      @default(0)
  createdAt       DateTime @default(now())
  ttl             Int?
  lastHeartbeat   DateTime @default(now())
  
  @@index([engineType])
  @@index([status])
  @@index([createdAt])
}

model DistressBeacon {
  id              String   @id @default(uuid())
  beaconId        String   @unique
  severity        String   @db.VarChar(20)
  recommendations String   @db.Text
  responsesTriggered Int    @default(0)
  createdAt       DateTime @default(now())
  
  @@index([severity])
  @@index([createdAt])
}
