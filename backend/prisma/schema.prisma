// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model VaultUnseal {
  id        String   @id @default(uuid())
  shardHash String   // SHA-256 hash to audit without storing the shard
  provider  String   // Identifier for the admin submitting the shard
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   @default("CASEWORKER")
  cases     Case[]
  assessments RiskAssessment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RiskAssessment {
  id              String   @id @default(uuid())
  caseId          String   @unique
  case            Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  riskLevel       String
  score           Float    @default(0)
  factors         String[] @default([])
  recommendations String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Resource {
  id        String   @id @default(uuid())
  name      String
  category  String
  capacity  Int
  available Int      @default(0)
  isActive  Boolean  @default(true)
  status    String   @default("ACTIVE")
  
  address   String?
  latitude  Float?
  longitude Float?
  phone     String?
  email     String?
  website   String?
  hours     String?
  
  createdAt DateTime @default(now())
  cases     Case[]
}

model Case {
  id                String             @id @default(uuid())
  userId            String?
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  title             String
  description       String
  status            String             @default("NEW")
  urgencyScore      Int?
  categoryTag       String?
  riskFactors       String[]           @default([])
  assignedResourceId String?
  assignedResource  Resource?          @relation(fields: [assignedResourceId], references: [id], onDelete: SetNull)
  enrichedAt        DateTime?
  routedAt          DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  assessment        RiskAssessment?
}

// ============================================================================
// SENTINEL D - AUTONOMOUS SYSTEM MODELS
// ============================================================================

model CivicResourceSnapshot {
  id              String   @id @default(uuid())
  externalId      String   @unique
  name            String
  resourceType    String   @db.VarChar(50)
  provider        String   @db.VarChar(100)
  address         String
  city            String
  capacity        Int?
  available       Int?
  verified        Boolean  @default(true)
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  
  @@index([resourceType])
  @@index([provider])
  @@index([lastSyncedAt])
}

model SentinelHeartbeat {
  id              String   @id @default(uuid())
  timestamp       DateTime @default(now())
  uptime          Int
  memoryHeapUsed  Int
  memoryHeapTotal Int
  cpuUser         Int
  cpuSystem       Int
  status          String   @db.VarChar(20)
  
  @@index([timestamp])
  @@index([status])
}

model TelemetryEvent {
  id              String   @id @default(uuid())
  traceId         String
  eventType       String   @db.VarChar(100)
  severity        String   @db.VarChar(20)
  payload         String   @db.Text
  source          String   @db.VarChar(50)
  timestamp       DateTime @default(now())
  
  @@index([traceId])
  @@index([eventType])
  @@index([severity])
  @@index([timestamp])
}

model DriftReport {
  id              String   @id @default(uuid())
  hasDrift        Boolean
  issueCount      Int
  details         String   @db.Text
  severity        Int
  timestamp       DateTime @default(now())
  
  @@index([hasDrift])
  @@index([severity])
  @@index([timestamp])
}

// ============================================================================
// SENTINEL ENGINE MODELS
// ============================================================================

model SentinelMetric {
  id              String   @id @default(uuid())
  metricType      String   @db.VarChar(50)
  resourceName    String   @db.VarChar(100)
  value           Float
  unit            String   @db.VarChar(20)
  timestamp       DateTime @default(now())
  
  @@index([resourceName])
  @@index([metricType])
  @@index([timestamp])
}

model SentinelCircuitState {
  id              String   @id @default(uuid())
  resourceName    String   @unique @db.VarChar(100)
  state           String   @db.VarChar(20)
  failureCount    Int      @default(0)
  lastFailureTime DateTime?
  updatedAt       DateTime @updatedAt
  
  @@index([state])
}

model NormalizationLog {
  id              String   @id @default(uuid())
  provider        String   @db.VarChar(100)
  totalRecords    Int
  successCount    Int
  failureCount    Int
  errorDetails    String?  @db.Text
  timestamp       DateTime @default(now())
  
  @@index([provider])
  @@index([timestamp])
}

// ============================================================================
// ENCRYPTION MODELS
// ============================================================================

model EncryptedResource {
  id              String   @id @default(uuid())
  resourceType    String   @db.VarChar(50)
  ciphertext      Bytes
  iv              Bytes
  authTag         Bytes
  encryptedDek    Bytes
  salt            Bytes
  keyVersion      Int      @default(1)
  associatedId    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?
  
  @@index([resourceType])
  @@index([keyVersion])
  @@index([createdAt])
}

model VaultAuditLog {
  id              String   @id @default(uuid())
  eventType       String   @db.VarChar(100)
  component       String   @db.VarChar(50) @default("SentinelEngine")
  resourceId      String?
  eventData       String?  @db.Text
  result          String   @db.VarChar(20)
  errorCode       String?  @db.VarChar(50)
  timestamp       DateTime @default(now())
  
  @@index([eventType])
  @@index([timestamp])
  @@index([result])
}

// ============================================================================
// LOAD MONITORING & AUTO-SCALING MODELS
// ============================================================================

model PlatformMetric {
  id              String   @id @default(uuid())
  totalRequests   Int
  totalCapacity   Int
  cpuUsage        Float
  memoryUsage     Float
  errorRate       Float
  avgResponseTime Float
  healthStatus    String   @db.VarChar(20)
  timestamp       DateTime @default(now())
  
  @@index([healthStatus])
  @@index([timestamp])
}

model EngineClone {
  id              String   @id @default(uuid())
  engineType      String   @db.VarChar(50)
  parentInstanceId String  @db.VarChar(100)
  status          String   @db.VarChar(20)
  maxCapacity     Int
  activeRequests  Int      @default(0)
  createdAt       DateTime @default(now())
  ttl             Int?
  lastHeartbeat   DateTime @default(now())
  
  @@index([engineType])
  @@index([status])
  @@index([createdAt])
}

model DistressBeacon {
  id              String   @id @default(uuid())
  beaconId        String   @unique
  severity        String   @db.VarChar(20)
  recommendations String   @db.Text
  responsesTriggered Int    @default(0)
  createdAt       DateTime @default(now())
  
  @@index([severity])
  @@index([createdAt])
}

// ===== TRANSIT SYSTEM MODELS =====

model TransitRoute {
  id              String    @id @default(cuid())
  routeName       String
  routeNumber     String?
  routeColor      String    @default("#000000")
  textColor       String    @default("#FFFFFF")
  transitMode     String    // bus, train, light-rail, subway, plane, ferry, etc.
  transportationType String  // ground, air, water
  description     String?   @db.LongText
  operatingHours  Json?     // { start: "05:00", end: "23:00" }
  agency          String?
  
  isActive        Boolean   @default(true)
  
  stops           TransitStop[]
  vehicles        TransitVehicle[]
  arrivals        TransitArrival[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([transitMode])
  @@index([transportationType])
  @@index([isActive])
}

model TransitStop {
  id              String    @id @default(cuid())
  routeId         String
  route           TransitRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  stopName        String
  latitude        Float
  longitude       Float
  address         String?
  sequence        Int
  
  arrivals        TransitArrival[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([routeId, sequence])
  @@index([routeId])
}

model TransitVehicle {
  id              String    @id @default(cuid())
  routeId         String
  route           TransitRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  vehicleNumber   String    @unique
  currentLatitude Float
  currentLongitude Float
  currentStopId   String?
  nextStopId      String?
  
  status          String    // in-transit, stopped, delayed, out-of-service
  occupancy       Int?      // 0-100 percentage
  heading         Int?      // 0-360 degrees
  speed           Float?    // km/h
  
  lastUpdate      DateTime  @default(now()) @updatedAt
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  
  @@index([routeId])
  @@index([isActive])
  @@index([lastUpdate])
}

model TransitArrival {
  id              String    @id @default(cuid())
  routeId         String
  route           TransitRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  
  stopId          String
  stop            TransitStop @relation(fields: [stopId], references: [id], onDelete: Cascade)
  
  vehicleId       String?
  arrivalTime     DateTime
  departureTime   DateTime?
  
  status          String    // on-time, delayed, cancelled
  occupancy       Int?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([stopId])
  @@index([routeId])
  @@index([arrivalTime])
}

model OmegisAuditLog {
  id              String    @id @default(cuid())
  userId          String
  toolName        String
  parameters      String?   @db.LongText
  classificationStage String
  approved        Boolean
  confidence      Float
  reason          String?
  context         String?   @db.LongText
  
  createdAt       DateTime  @default(now())
  
  @@index([userId])
  @@index([approved])
  @@index([createdAt])
}

