# ── HAVEN Environment Variables ──────────────────────────────────────────────
# cp .env.example .env  — then fill in real values.
# NEVER commit .env to git. Every secret below must be rotated before go-live.
# Generate random secrets: openssl rand -hex 32

# ════════════════════════════════════════════════════════════════════════════
# SECTION 1 — DATABASE
# ════════════════════════════════════════════════════════════════════════════

MONGO_URL=mongodb://mongo:27017
DB_NAME=haven

# ════════════════════════════════════════════════════════════════════════════
# SECTION 2 — AUTHENTICATION
# ════════════════════════════════════════════════════════════════════════════

# JWT signing secret — min 32 chars. Rotate to invalidate all active sessions.
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32

# JWT token lifetime (hours). 72h default. Reduce for higher-security deployments.
JWT_EXPIRE_HOURS=72

# JWT algorithm. HS256 (HMAC-SHA256) for single-node; RS256 for multi-node.
JWT_ALGORITHM=HS256

# ════════════════════════════════════════════════════════════════════════════
# SECTION 3 — APEX VAULT (AES-256-GCM envelope encryption — SOC 2 CC6.1/CC6.7)
# ════════════════════════════════════════════════════════════════════════════

# Master key for the Apex Vault. Min 32 chars. NEVER reuse JWT_SECRET in prod.
# If unset, falls back to JWT_SECRET (dev only — NOT acceptable for SOC 2 audit).
# Generate: openssl rand -hex 32
VAULT_MASTER_KEY=CHANGE_ME_openssl_rand_hex_32

# ════════════════════════════════════════════════════════════════════════════
# SECTION 4 — SIGNED URLS (SOC 2 CC6.7 — document access control)
# ════════════════════════════════════════════════════════════════════════════

# HMAC-SHA256 signing secret for document download URLs. Separate from JWT.
# Generate: openssl rand -hex 32
SIGNED_URL_SECRET=CHANGE_ME_openssl_rand_hex_32

# Signed URL time-to-live in seconds. Default 900 (15 min).
# Reduce to 300 (5 min) for higher-security deployments.
SIGNED_URL_TTL_SECONDS=900

# Document blob storage backend: local (MongoDB, default) or s3
BLOB_STORE_BACKEND=local

# Public base URL used to construct signed download URLs.
PUBLIC_BASE_URL=https://homeishaven.cloud

# S3 bucket — only required when BLOB_STORE_BACKEND=s3
# S3_DOCUMENT_BUCKET=haven-documents-prod
# AWS_REGION=us-west-2

# ════════════════════════════════════════════════════════════════════════════
# SECTION 5 — LLM / AI ENGINE
# ════════════════════════════════════════════════════════════════════════════

# Ollama — primary LLM, runs locally inside Docker, zero API cost.
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=90

# Emergent LLM fallback (Claude Sonnet). Leave blank to fully disable.
# Only activates if Ollama is unreachable.
EMERGENT_LLM_KEY=

# ════════════════════════════════════════════════════════════════════════════
# SECTION 6 — CORS & NETWORKING
# ════════════════════════════════════════════════════════════════════════════

CORS_ORIGINS=https://homeishaven.cloud,https://www.homeishaven.cloud
ENVIRONMENT=production

# Frontend Vite build arg
VITE_API_URL=https://homeishaven.cloud/api

# ════════════════════════════════════════════════════════════════════════════
# SECTION 7 — OAUTH / AGENCY INTEGRATIONS (FedRAMP IA-5)
# ════════════════════════════════════════════════════════════════════════════

# Global OAuth environment: sandbox | prod
OAUTH_ENV=sandbox

# OAuth redirect URI — must match registration in Login.gov / VA / SSA portals.
OAUTH_REDIRECT_URI=https://homeishaven.cloud/api/integrations/oauth/callback

# OAuth state token TTL in seconds. Default 900 (15 min). Single-use enforced.
OAUTH_STATE_TTL_SECONDS=900

# Token auto-refresh: seconds before expiry to trigger proactive rotation.
# Default 300 (5 min before expiry). Set to 0 to disable auto-refresh.
TOKEN_REFRESH_BUFFER_SECONDS=300

# ── Per-agency credentials (Login.gov sandbox example) ──────────────────────
# Uncomment and fill to enable live OAuth for each agency.
# All secrets are vault-encrypted before storage — safe to rotate at any time.

# HUD_SEC8_OAUTH_CLIENT_ID=
# HUD_SEC8_OAUTH_CLIENT_SECRET=
# HUD_SEC8_ADAPTER=logingov

# VA_BENEFITS_OAUTH_CLIENT_ID=
# VA_BENEFITS_ADAPTER=va

# SSA_SSI_OAUTH_CLIENT_ID=
# SSA_SSI_ADAPTER=ssa

# USDA_SNAP_OAUTH_CLIENT_ID=
# CMS_MEDICAID_OAUTH_CLIENT_ID=
# IRS_EFILE_OAUTH_CLIENT_ID=
# DOL_UI_OAUTH_CLIENT_ID=
# DMV_ID_OAUTH_CLIENT_ID=
# HHS_TANF_OAUTH_CLIENT_ID=
# WIC_CA_OAUTH_CLIENT_ID=

# ════════════════════════════════════════════════════════════════════════════
# SECTION 8 — GDPR / CCPA DATA RETENTION
# ════════════════════════════════════════════════════════════════════════════

# Audit log retention in days. Default 2555 (7 years — IRS / HIPAA standard).
AUDIT_LOG_RETENTION_DAYS=2555

# BB session retention in days. Default 90.
BB_SESSION_RETENTION_DAYS=90

# Notification retention in days. Default 30.
NOTIFICATION_RETENTION_DAYS=30

# ════════════════════════════════════════════════════════════════════════════
# SECTION 9 — MONITORING (SOC 2 A1 — Availability)
# ════════════════════════════════════════════════════════════════════════════

# Sentry DSN for error tracking. Leave blank to disable.
SENTRY_DSN=

# Uptime target SLA percentage for health reporting.
UPTIME_TARGET_PCT=99.2
