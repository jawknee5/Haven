# ── HAVEN Environment Variables ─────────────────────────────────────────────
# cp .env.example .env  — then fill in real values. NEVER commit .env to git.

# ── MongoDB ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://mongo:27017
DATABASE_NAME=haven

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME

# ── Ollama (primary LLM — free, runs locally inside Docker) ──────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=90

# ── Emergent LLM fallback ─────────────────────────────────────────────────────
# Leave blank to fully disable Claude Sonnet and stop all credit usage.
# Only set this if Ollama is down and you want an automatic fallback.
EMERGENT_LLM_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://homeishaven.cloud,https://www.homeishaven.cloud

# ── Frontend Vite build arg ───────────────────────────────────────────────────
VITE_API_URL=https://homeishaven.cloud/api
