/**
 * Xortron-Apex Prisma Schema
 * Government-Grade Encrypted Storage
 * 
 * This schema implements:
 * - Encrypted blob storage (ciphertext + metadata)
 * - Versioned key tracking
 * - Audit trail for all operations
 * - Zero-knowledge database state
 */

// This file should be added to your prisma/schema.prisma

// ============================================================================
// ENCRYPTED RESOURCE MODEL
// ============================================================================

model EncryptedResource {
  /// Unique identifier for this encrypted record
  id              String   @id @default(uuid())
  
  /// Resource classification (SENSITIVE_PII, TRANSITION_PLAN, FINANCIAL_DATA, etc.)
  resourceType    String   @db.VarChar(50)
  
  /// The encrypted payload (ciphertext)
  ciphertext      Bytes
  
  /// Initialization vector (12 bytes for GCM)
  iv              Bytes
  
  /// Authentication tag (16 bytes for GCM)
  authTag         Bytes
  
  /// The Data Encryption Key, wrapped/encrypted with the Key Encryption Key
  encryptedDek    Bytes
  
  /// Salt used for key derivation (PBKDF2/Scrypt)
  salt            Bytes
  
  /// Key version used for encryption (tracks which KEK version)
  keyVersion      Int      @default(1)
  
  /// Associated user (for multi-tenant scenarios)
  userId          String?
  
  /// Metadata tags for searching/categorizing (non-sensitive)
  tags            String?  @db.Text
  
  /// Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  /// Soft-delete support (for audit trail)
  deletedAt       DateTime?
  
  // Indexes for common queries
  @@index([resourceType])
  @@index([userId])
  @@index([keyVersion])
  @@index([createdAt])
}

// ============================================================================
// KEY METADATA MODEL
// ============================================================================

model EncryptionKeyMetadata {
  /// Unique identifier for this key version
  id              String   @id @default(uuid())
  
  /// Key version number (incremental)
  version         Int      @unique
  
  /// Status: ACTIVE, DEPRECATED, ARCHIVED
  status          String   @db.VarChar(20)
  
  /// Algorithm used (aes-256-gcm)
  algorithm       String   @db.VarChar(50)
  
  /// Key ID (for HSM tracking)
  keyId           String   @unique
  
  /// When this key was created
  createdAt       DateTime @default(now())
  
  /// When this key was rotated out
  rotatedAt       DateTime?
  
  /// Fingerprint (for integrity verification)
  fingerprint     String?
  
  @@index([status])
  @@index([version])
}

// ============================================================================
// AUDIT TRAIL MODEL
// ============================================================================

model VaultAuditLog {
  /// Unique audit entry ID
  id              String   @id @default(uuid())
  
  /// Event type: ENCRYPTION_SUCCESS, DECRYPTION_SUCCESS, INTEGRITY_CHECK_FAILED, etc.
  eventType       String   @db.VarChar(100)
  
  /// Component that generated the event
  component       String   @db.VarChar(50) @default("XortronApexVault")
  
  /// Resource ID (encrypted resource that was accessed)
  resourceId      String?
  
  /// User ID (who triggered this event, if applicable)
  userId          String?
  
  /// Detailed event data (JSON)
  eventData       String?  @db.Text
  
  /// Result: SUCCESS, FAILURE, REJECTED
  result          String   @db.VarChar(20)
  
  /// Error code (if applicable)
  errorCode       String?  @db.VarChar(50)
  
  /// Timestamp (precise, for chronological audit trail)
  timestamp       DateTime @default(now())
  
  /// Client IP (for detecting unauthorized access patterns)
  clientIp        String?
  
  @@index([eventType])
  @@index([userId])
  @@index([timestamp])
  @@index([result])
}

// ============================================================================
// KEY ROTATION HISTORY MODEL
// ============================================================================

model KeyRotationHistory {
  /// Unique rotation record ID
  id              String   @id @default(uuid())
  
  /// From key version
  fromKeyVersion  Int
  
  /// To key version
  toKeyVersion    Int
  
  /// Total records rotated
  totalRecords    Int
  
  /// Records successfully rotated
  successCount    Int
  
  /// Records that failed rotation
  failureCount    Int
  
  /// Rotation start time
  startedAt       DateTime @default(now())
  
  /// Rotation completion time
  completedAt     DateTime?
  
  /// Status: IN_PROGRESS, COMPLETED, FAILED
  status          String   @db.VarChar(20)
  
  /// Notes/error details
  notes           String?  @db.Text
  
  @@index([status])
  @@index([startedAt])
}

